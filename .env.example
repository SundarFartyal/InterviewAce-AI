# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Anthropic (answer evaluation) ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Sheets storage ---
# Path to the downloaded service account JSON (relative or absolute).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# The spreadsheet ID, taken from its URL:
#   https://docs.google.com/spreadsheets/d/<THIS_IS_THE_KEY>/edit
GOOGLE_SHEET_KEY=your-spreadsheet-id-here

# Optional fallback if you prefer opening by title instead of by key:
GOOGLE_SHEET_NAME=InterviewAce AI
